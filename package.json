{
  "name": "iprep",
  "version": "1.0.0",
  "private": false,
  "description": "iPrep — AI-powered interview preparation platform (monorepo root)",
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
